TG_API_ID=
TG_API_HASH=
# Absolute path inside the listener container (./data on the host is bind-mounted to /app/data).
# If running outside Docker, override with a host path.
TG_SESSION=/app/data/listener

# Supergroup/channel dialog ID (the -100... form). Leave blank to listen to all chats.
TG_CHAT_ID=
# Forum topic ID. Leave blank to listen to all topics in the chat.
TG_TOPIC_ID=

# Kafka. Reachable only inside the compose network — services use kafka:9092.
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC=telegram-events
KAFKA_ACTIONS_TOPIC=trade-actions
KAFKA_GROUP_ID=telegram-consumer
EXECUTOR_GROUP_ID=forex-executor

# Claude API. Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Text-only messages use the cheap model; messages with an image use the vision model.
ANTHROPIC_MODEL_TEXT=claude-haiku-4-5
ANTHROPIC_MODEL_IMAGE=claude-opus-4-7

# Redis — conversation thread per chat/topic, persisted across restarts.
# Reachable only inside compose. Server-side compaction bounds the per-chat size.
REDIS_URL=redis://redis:6379/0

# MetaApi — forex broker bridge. Get token + accountId from https://app.metaapi.cloud/
METAAPI_TOKEN=
METAAPI_ACCOUNT_ID=
DEFAULT_VOLUME=0.01
